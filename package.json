{
  "name": "apitubes",
  "version": "1.0.0",
  "description": "Express-based backend API showcase with authentication, bookings, rooms, inventory, events, announcements, and Swagger docs.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "test": "cross-env NODE_ENV=test jest --runInBand --detectOpenHandles --forceExit",
    "test:coverage": "NODE_ENV=test jest --runInBand --detectOpenHandles --forceExit --coverage"
  },
  "keywords": [
    "express",
    "nodejs",
    "rest-api",
    "sqlite",
    "swagger",
    "backend"
  ],
